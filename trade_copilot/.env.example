BINANCE_API_KEY=put_restricted_futures_api_key_here
BINANCE_API_SECRET=put_restricted_futures_api_secret_here

# Optional. Defaults to Binance USD-M futures production API.
BINANCE_FAPI_BASE_URL=https://fapi.binance.com

# Optional local futures guard. Live orders outside this comma-separated list are refused.
ALLOWED_SYMBOLS=RAVEUSDT,HIGHUSDT,ALICEUSDT,PORTALUSDT,SIRENUSDT
